# Copy this file to .env (git-ignored) and fill in your values.
# Docker Compose loads .env automatically from this directory.
#
# The reconciler authenticates to rstream with an agent token for your project.
RSTREAM_ENGINE=<engine-host>:443
RSTREAM_AUTHENTICATION_TOKEN=<agent-token>

# Optional — these only affect what the pool shows. The model list itself is read
# from the worker's own /v1/models, so there is nothing to declare here: whatever
# you `ollama pull` appears automatically.
# PLLM_CTX=8192
# PLLM_ACCEL=cpu
# PLLM_HOST=ollama
