# Copy to .env.local and fill in. The app authenticates to rstream with
# application client credentials and mints its own short-lived, scoped tokens.

# --- rstream (required) ---
RSTREAM_CLIENT_ID=
RSTREAM_CLIENT_SECRET=
# One of these identifies the project (the 8-hex endpoint is the usual one):
RSTREAM_PROJECT_ENDPOINT=
# RSTREAM_PROJECT_ID=
# Optional direct engine override for that project:
# RSTREAM_ENGINE=

# Optional hosted API override.
# RSTREAM_API_URL=https://rstream.io

# --- auth ---
# Required for signed JWT sessions: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub SSO. Configure at least one allowlist below.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Allowlist for GitHub sign-ins (any match grants access; unset = closed).
# ALLOWED_EMAIL_DOMAINS=your-org.com
# ALLOWED_EMAILS=alice@your-org.com,bob@your-org.com
# ALLOWED_GITHUB_LOGINS=alice,bob

# Local quickstart only: skip sign-in entirely (everyone is one local user).
# AUTH_DISABLED=true

# --- tools (optional) ---
# Web search and fetch (Tavily). Without a key these run in a rate-limited
# keyless mode; set a key for reliable access.
# TAVILY_API_KEY=

# --- token lifetimes (optional; sensible defaults) ---
# CONNECT_TOKEN_TTL_SECONDS=300
# WATCH_TOKEN_TTL_SECONDS=120
